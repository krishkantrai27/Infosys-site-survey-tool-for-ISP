# ========================================
# Node / Frontend (.gitignore)
# ========================================
node_modules/
dist/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache
.vite/

# ========================================
# Java / Maven / Backend (.gitignore)
# ========================================
target/
*.class
*.jar
*.war
*.ear
*.log

# ========================================
# IDEs and Tools (.gitignore)
# ========================================
.idea/
*.iml
.vscode/
*.swp
.DS_Store

# ========================================
# Environment Variables & Configs
# ========================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
docker-compose.yml
